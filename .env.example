# 니노 봇 환경변수 템플릿
# 이 파일을 .env로 복사해서 값을 채워넣으세요

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TMUX_SESSION=nino
ALARM_TOOL_SESSION=nino
PICOVOICE_ACCESS_KEY=

# 헬스체크
HEALTH_PORT=58090
HEALTH_TARGETS=haru:http://<HARU_IP>:58090,rund:http://<RUND_IP>:58090

# 디렉토리 설정
NINO_LOG_DIR=/home/<USER>/discord-bot-nino/logs
NINO_STATE_DIR=/home/<USER>/discord-bot-nino/logs/presence-state
